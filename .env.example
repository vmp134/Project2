# Postgres hostname - do not change this
DB_HOST=postgres.cs.rutgers.edu

# Postgres port - do not change this
DB_PORT=5432

# Your Rutgers Postgres database name (usually your netid)
# Fill this in with your assigned database name
DB_NAME=

# Your Rutgers netid
DB_USER=

# Your Postgres password for postgres.cs.rutgers.edu
DB_PASSWORD=

# Full command to invoke ilab_script.py on the ilab machine.
# Format: /path/to/venv/python3 /path/to/ilab_script.py
# Example: /common/home/NETID/cs336/p2venv/bin/python3 /common/home/NETID/cs336/Project2/ilab_script.py
# Fill in your own ilab path before running.
ILAB_SCRIPT=